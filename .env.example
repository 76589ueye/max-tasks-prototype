# Database Configuration
# In development, you can point this to the Docker PostgreSQL container:
DATABASE_URL="postgresql://postgres:password123@localhost:5432/maxtasks?schema=public"
# Alternatively, to run without postgres during dev, you can use SQLite:
# DATABASE_URL="file:./dev.db"

# API Service Configuration
PORT=8080
NODE_ENV=development
JWT_SECRET="super-secret-jwt-key-change-this-in-production"

# CORS / Origin Configuration
CLIENT_ORIGIN="http://localhost:3000"

# S3/R2 Storage Config (Optional - Fallbacks to local files if empty)
STORAGE_PROVIDER=local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET_NAME=

# Web App Configuration
NEXT_PUBLIC_API_URL="http://localhost:8080/api/v1"
